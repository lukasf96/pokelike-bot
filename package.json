{
  "name": "pokebot",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "dist/bot.js",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "start": "tsx src/bot.ts",
    "build": "tsc",
    "dev": "tsx watch src/bot.ts",
    "lint": "eslint \"{src,tests,scripts}/**/*.{ts,mjs}\"",
    "lint:fix": "eslint \"{src,tests,scripts}/**/*.{ts,mjs}\" --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "node --import tsx --test --test-reporter=spec \"tests/**/*.test.ts\"",
    "test:unit": "node --import tsx --test --test-reporter=spec \"tests/unit/**/*.test.ts\"",
    "test:contract": "node --import tsx --test --test-reporter=spec \"tests/contract/**/*.test.ts\"",
    "test:coverage": "node --import tsx --test --experimental-test-coverage --test-coverage-exclude=\"src/bot.ts\" --test-coverage-exclude=\"src/utility/page-utils.ts\" --test-coverage-exclude=\"src/logging/logger.ts\" --test-coverage-exclude=\"src/logging/run-detail-log.ts\" --test-coverage-exclude=\"src/state/snapshot.ts\" --test-coverage-exclude=\"src/state/handler.ts\" --test-coverage-exclude=\"src/handlers/**\" --test-coverage-exclude=\"tests/**\" --test-reporter=spec \"tests/**/*.test.ts\"",
    "gen:species": "node scripts/fetch-gen1-species.mjs",
    "gen:base-stats": "node scripts/fetch-gen1-base-stats.mjs",
    "gen:typechart": "node scripts/fetch-type-chart.mjs",
    "gen:pokeapi-data": "node scripts/fetch-gen1-species.mjs && node scripts/fetch-type-chart.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "puppeteer": "^24.41.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2"
  }
}
